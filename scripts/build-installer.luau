--- Generates dist/install.luau: a single script that, pasted into the Studio
--- command bar, recreates the whole Material tree under ReplicatedStorage.
--- Run with `lune run scripts/build-installer`.

local fs = require("@lune/fs")
local luau = require("@lune/luau")

type Entry = { path: string, class: string, source: string? }
local entries: { Entry } = {}

local function findInit(dir: string): string?
	for _, name in { "init.lua", "init.luau" } do
		if fs.isFile(dir .. "/" .. name) then
			return dir .. "/" .. name
		end
	end
	return nil
end

local function walk(dir: string, path: string)
	local names = fs.readDir(dir)
	table.sort(names)
	for _, name in names do
		local full = dir .. "/" .. name
		if fs.isDir(full) then
			local childPath = path .. "/" .. name
			local init = findInit(full)
			entries[#entries + 1] = {
				path = childPath,
				class = if init then "ModuleScript" else "Folder",
				source = if init then fs.readFile(init) else nil,
			}
			walk(full, childPath)
		elseif string.match(name, "%.luau?$") and not string.match(name, "^init%.luau?$") then
			entries[#entries + 1] = {
				path = path .. "/" .. (string.gsub(name, "%.luau?$", "")),
				class = "ModuleScript",
				source = fs.readFile(full),
			}
		end
	end
end

local rootInit = findInit("src")
assert(rootInit, "src/ needs an init.lua")
entries[#entries + 1] = { path = "Material", class = "ModuleScript", source = fs.readFile(rootInit :: string) }
walk("src", "Material")

local lines: { string } = {
	"-- Material installer (generated by scripts/build-installer — do not edit)",
	"-- Paste this whole file into the Roblox Studio command bar.",
	"-- Recreates ReplicatedStorage.Material (a fork of TopbarPlus v3.4.0).",
	"local MODULES = {",
}
for _, entry in entries do
	local source = if entry.source then string.format("%q", entry.source) else "nil"
	lines[#lines + 1] = string.format("{%q,%q,%s},", entry.path, entry.class, source)
end
lines[#lines + 1] = [==[
}
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local old = ReplicatedStorage:FindFirstChild("Material")
if old then
	old:Destroy()
	warn("Material: replaced the existing ReplicatedStorage.Material")
end
local byPath = {}
for _, entry in MODULES do
	local path, className, source = entry[1], entry[2], entry[3]
	local instance = Instance.new(className)
	instance.Name = string.match(path, "([^/]+)$")
	if source then
		instance.Source = source
	end
	local parentPath = string.match(path, "^(.+)/[^/]+$")
	instance.Parent = if parentPath then byPath[parentPath] else ReplicatedStorage
	byPath[path] = instance
end
print(("Material installed to ReplicatedStorage.Material (%d instances)"):format(#MODULES))
]==]

local bundle = table.concat(lines, "\n")

-- self-check: the installer must at least compile as Luau
local ok, err = pcall(luau.load, bundle, { debugName = "install.luau" })
assert(ok, `generated installer does not compile: {err}`)

if not fs.isDir("dist") then
	fs.writeDir("dist")
end
fs.writeFile("dist/install.luau", bundle)
print(`bundled dist/install.luau ({math.round(#bundle / 1024)}K, {#entries} instances)`)
